{
  "name": "paire",
  "version": "1.0.0",
  "description": "Local LLM-free review state engine for coding agents.",
  "type": "module",
  "private": true,
  "bin": {
    "paire": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile=dist/paire",
    "release:local": "bash scripts/build-release.sh",
    "smoke": "bun scripts/smoke-cli.ts",
    "test": "bun test",
    "typecheck": "bunx tsc -p jsconfig.json --noEmit"
  },
  "keywords": [
    "cli",
    "code-review",
    "coding-agents"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@pierre/diffs": "^1.2.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5"
  }
}
