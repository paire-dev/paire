{
  "name": "paire",
  "version": "1.0.0",
  "description": "Local LLM-free review state engine for coding agents.",
  "type": "module",
  "private": true,
  "bin": {
    "paire": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun scripts/build.ts --outfile=dist/paire",
    "release:local": "bash scripts/build-release.sh",
    "smoke": "bun scripts/smoke-cli.ts",
    "test": "bun test",
    "typecheck": "bun x tsc -p jsconfig.json --noEmit"
  },
  "keywords": [
    "cli",
    "code-review",
    "coding-agents"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@pierre/diffs": "^1.2.5",
    "@pierre/trees": "^1.0.0-beta.4",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "shadcn": "^4.10.0",
    "typescript": "^5"
  }
}
